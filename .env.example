# =============================================================================
# Copy this file to `.env.local` (for local dev) and add real values.
# For production, set these in the Vercel dashboard: Settings → Environment Variables.
# NEVER commit `.env.local` — it's in .gitignore.
# =============================================================================

# ---- Supabase ----
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
# SERVICE ROLE key bypasses RLS. Only use in server-side code. Never expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# These two are the ONLY secrets the frontend needs — prefix them so Vite/Next conventions work
# even though we're vanilla HTML. Our frontend reads window.ENV injected by the server.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ---- Anthropic API ----
# Used by /api/scan for the tier-2 fallback (Claude Haiku reads career pages)
# Get this from https://console.anthropic.com — use a scoped key with a monthly spending limit
ANTHROPIC_API_KEY=sk-ant-...

# ---- Cron security ----
# A secret string the cron job must send to prove it's legitimate (not someone hitting the URL)
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me-with-random-hex
